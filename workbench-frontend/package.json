{
  "name": "@workbench/frontend",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "paraglide": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide --emit-ts-declarations",
    "predev": "pnpm paraglide",
    "dev": "vite dev",
    "prebuild": "pnpm paraglide",
    "build": "vite build && node scripts/check-bundle-size.mjs",
    "preview": "vite preview",
    "precheck": "pnpm paraglide",
    "check": "node scripts/ensure-env.mjs && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint . && pnpm check",
    "test:unit": "vitest --project unit --run",
    "coverage": "pnpm coverage:unit",
    "coverage:unit": "vitest --project unit --run --coverage --coverage.reportsDirectory=./coverage/unit",
    "coverage:storybook": "vitest --project storybook --run --coverage --coverage.reportsDirectory=./coverage/storybook",
    "coverage:merge:vitest": "vitest-coverage-merge coverage/unit coverage/storybook -o coverage/vitest --reporters html,lcov,json",
    "coverage:full": "pnpm coverage:unit && pnpm coverage:storybook && pnpm exec vitest-coverage-merge coverage/unit coverage/storybook -o coverage/full",
    "coverage:e2e": "node tests/e2e/stack/collect-e2e-coverage.mjs",
    "storybook": "storybook dev --port 6006",
    "storybook:build": "storybook build --output-dir storybook-static",
    "storybook:test": "vitest --project storybook --run --coverage --coverage.include='src/lib/**/*.svelte' --coverage.exclude='src/**/*.stories.svelte' --coverage.reporter=lcov --coverage.reportsDirectory=./coverage/storybook-components && node scripts/storybook-component-coverage.mjs",
    "test:e2e": "playwright test",
    "test:e2e:coverage": "E2E_COLLECT_COVERAGE=true playwright test",
    "test:e2e:stack": "node tests/e2e/stack/run.mjs",
    "openapi": "orval --config orval.config.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@inlang/paraglide-js": "2.22.0",
    "@lucide/svelte": "1.24.0",
    "@sveltejs/adapter-auto": "7.0.1",
    "@sveltejs/kit": "2.69.2",
    "@sveltejs/vite-plugin-svelte": "7.2.0",
    "@tanstack/svelte-query": "^6.1.36",
    "@tanstack/svelte-table": "^8.21.3",
    "@tanstack/table-core": "^8.21.3",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-bubble-menu": "^3.27.3",
    "@tiptap/extension-code-block-lowlight": "^3.27.3",
    "@tiptap/extension-placeholder": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/suggestion": "^3.27.3",
    "clsx": "2.1.1",
    "highlight.js": "^11.11.1",
    "lowlight": "^3.3.0",
    "monaco-editor": "^0.55.1",
    "svelte": "5.56.4",
    "svelte-dnd-action": "^0.9.74",
    "tailwind-merge": "3.6.0",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "9.1.0",
    "@internationalized/date": "^3.12.2",
    "@playwright/test": "1.61.1",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/sveltekit": "^10.5.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/svelte": "5.4.2",
    "@types/node": "26.1.1",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "bits-ui": "^2.16.3",
    "eslint": "10.7.0",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-svelte": "^3.20.0",
    "jsdom": "29.1.1",
    "msw": "^2.15.0",
    "msw-storybook-addon": "^2.0.7",
    "nextcov": "^1.3.0",
    "orval": "8.20.0",
    "playwright": "1.61.1",
    "shadcn-svelte": "1.4.1",
    "storybook": "^10.5.0",
    "svelte-check": "4.7.1",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "vaul-svelte": "1.0.0-next.7",
    "vite": "8.1.4",
    "vitest": "4.1.10",
    "vitest-coverage-merge": "^0.2.0"
  },
  "msw": {
    "workerDirectory": [
      "static"
    ]
  }
}
