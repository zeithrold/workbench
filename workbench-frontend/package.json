{
  "name": "@workbench/frontend",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint . && pnpm check",
    "test:unit": "vitest --project unit --run",
    "coverage": "vitest --project unit --run --coverage",
    "storybook": "storybook dev --port 6006",
    "storybook:build": "storybook build --output-dir storybook-static",
    "storybook:test": "vitest --project storybook --run",
    "test:e2e": "playwright test",
    "openapi": "orval --config orval.config.ts"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@lucide/svelte": "latest",
    "@sveltejs/adapter-auto": "latest",
    "@sveltejs/kit": "latest",
    "@sveltejs/vite-plugin-svelte": "latest",
    "clsx": "latest",
    "svelte": "latest",
    "tailwind-merge": "latest",
    "tailwind-variants": "^3.2.2",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "latest",
    "@internationalized/date": "^3.12.2",
    "@playwright/test": "latest",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-svelte-csf": "^5.1.2",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/sveltekit": "^10.5.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/svelte": "latest",
    "@types/node": "latest",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "latest",
    "bits-ui": "^2.16.3",
    "eslint": "latest",
    "eslint-plugin-format": "^2.0.1",
    "eslint-plugin-svelte": "^3.20.0",
    "jsdom": "latest",
    "orval": "latest",
    "playwright": "latest",
    "shadcn-svelte": "latest",
    "storybook": "^10.5.0",
    "svelte-check": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
